# PostgreSQL database. Prisma Postgres, Neon, Supabase, or Vercel Postgres all work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Discord Developer Portal -> OAuth2
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Comma-separated Discord user IDs. These users are always Website Developers
# and receive every website permission regardless of their database role.
OWNER_DISCORD_IDS="123456789012345678,987654321098765432"

# Public site configuration
NEXT_PUBLIC_SITE_NAME="FreeWorld RP"
NEXT_PUBLIC_DISCORD_INVITE="https://discord.gg/yourinvite"
NEXT_PUBLIC_SERVER_CONNECT="cfx.re/join/replace"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
